OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=http://localhost:13000/v1
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large
OPENAI_LLM_MODEL=gpt-4o-mini
TEMPERATURE=0
MAX_TOKENS=2000

NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change_me
NEO4J_MAX_POOL_SIZE=10
NEO4J_REFRESH_SCHEMA=false

FASTAPI_WORKERS=2
MAX_WORKERS=4
MA_WORKER_EXECUTION_MODE=parallel
MA_WORKER_MAX_CONCURRENCY=4

CHUNK_SIZE=500
CHUNK_OVERLAP=100
MAX_TEXT_LENGTH=500000

CACHE_EMBEDDING_PROVIDER=sentence_transformer
CACHE_SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
CACHE_ENABLE_VECTOR_SIMILARITY=true
CACHE_SIMILARITY_THRESHOLD=0.9

SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_RELOAD=false
SERVER_LOG_LEVEL=info

FRONTEND_API_URL=http://localhost:8000
FRONTEND_DEFAULT_AGENT=fusion_agent
FRONTEND_DEFAULT_DEBUG=false
FRONTEND_SHOW_THINKING=true
FRONTEND_USE_STREAM=true

MA_DEFAULT_DOMAIN=industrial_knowledge_service
MA_AUTO_GENERATE_REPORT=true
MA_ENABLE_CONSISTENCY_CHECK=true

# Optional tracing
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=your_langsmith_key
# LANGSMITH_PROJECT=industrial-knowledge-service
